# URL for the local trial API server (started by `npm run trial:api` or `npm run demo`)
# Default when unset: http://localhost:8787
VITE_TRIAL_API_BASE_URL=http://localhost:8787

# Supabase project credentials (required — get from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Vercel-compatible aliases are also supported by src/lib/supabase.ts.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-side verification helpers may also read these names.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-for-rls-verification>

# Optional helper for `npm run verify:magic-link`.
STAGE7_MAGIC_LINK_EMAIL=<cohort-test-email>
