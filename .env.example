# URL for the local trial API server (started by `npm run trial:api` or `npm run demo`)
# Default when unset: http://localhost:8787
VITE_TRIAL_API_BASE_URL=http://localhost:8787

# Supabase project credentials (required — get from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
